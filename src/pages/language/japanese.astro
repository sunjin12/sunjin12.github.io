---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/japanese.json';
---

<BaseLayout title={data.pageTitle}>
  <section class="section">
    <h2 class="section-title">{data.sectionTitle}</h2>

    {data.certifications.map(cert => (
      <div class="cert-item">
        <div>
          <h4>{cert.title}</h4>
          <span class="score">{cert.score}</span>
        </div>
        <div class="pdf-thumb-group">
          {cert.pdfs.map(pdf => (
            <div class="pdf-thumb-wrap">
              <iframe src={`${pdf.path}#toolbar=0&navpanes=0&scrollbar=0&view=FitH`} class="pdf-thumb-frame"></iframe>
              <a href={pdf.path} class="pdf-thumb-overlay" download>
                <span class="pdf-download-hint">📥 {pdf.label}</span>
              </a>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
