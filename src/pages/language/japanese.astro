---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="일본어 — 길철휘">
  <section class="section">
    <h2 class="section-title">일본어</h2>

    <div class="cert-item">
      <div>
        <h4>JLPT</h4>
        <span class="score">N3</span>
      </div>
      <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
        <a href="/assets/pdf/jlpt-n3-certificate.pdf" class="download-btn" download>
          📄 합격증 PDF
        </a>
        <a href="/assets/pdf/jlpt-n3-result.pdf" class="download-btn" download>
          📄 결과지 PDF
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
