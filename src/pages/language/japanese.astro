---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="일본어 — 길철휘">
  <section class="section">
    <h2 class="section-title">일본어</h2>

    <div class="cert-item">
      <div>
        <h4>JLPT</h4>
        <span class="score">N3</span>
      </div>
      <div class="pdf-thumb-group">
        <div class="pdf-thumb-wrap">
          <iframe src="/assets/pdf/jlpt-n3-certificate.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH" class="pdf-thumb-frame"></iframe>
          <a href="/assets/pdf/jlpt-n3-certificate.pdf" class="pdf-thumb-overlay" download>
            <span class="pdf-download-hint">📥 합격증 다운로드</span>
          </a>
        </div>
        <div class="pdf-thumb-wrap">
          <iframe src="/assets/pdf/jlpt-n3-result.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH" class="pdf-thumb-frame"></iframe>
          <a href="/assets/pdf/jlpt-n3-result.pdf" class="pdf-thumb-overlay" download>
            <span class="pdf-download-hint">📥 결과지 다운로드</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
