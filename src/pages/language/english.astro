---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="영어 — 길철휘">
  <section class="section">
    <h2 class="section-title">영어</h2>

    <h3 style="margin-bottom: 1rem;">자격증</h3>

    <div class="cert-item">
      <div>
        <h4>TOEIC</h4>
        <span class="score">940</span>
      </div>
      <div class="pdf-thumb-wrap">
        <iframe src="/assets/pdf/toeic-score.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH" class="pdf-thumb-frame"></iframe>
        <a href="/assets/pdf/toeic-score.pdf" class="pdf-thumb-overlay" download>
          <span class="pdf-download-hint">📥 다운로드</span>
        </a>
      </div>
    </div>

    <div class="cert-item">
      <div>
        <h4>토익스피킹</h4>
        <span class="score">Level 6 — 130</span>
      </div>
      <div class="pdf-thumb-wrap">
        <iframe src="/assets/pdf/toeic-speaking-score.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH" class="pdf-thumb-frame"></iframe>
        <a href="/assets/pdf/toeic-speaking-score.pdf" class="pdf-thumb-overlay" download>
          <span class="pdf-download-hint">📥 다운로드</span>
        </a>
      </div>
    </div>

    <div class="cert-item">
      <div>
        <h4>토익스피킹</h4>
        <span class="score">IH — 140</span>
      </div>
      <img
        src="/assets/images/toeic-speaking-ih.png"
        alt="토익스피킹 IH 140점 성적"
        style="max-width: 400px;"
      />
    </div>
  </section>

  <section class="section">
    <h3 style="margin-bottom: 1rem;">학습 이력</h3>

    <div class="stat-block">
      <h3>말해보카 — 영어단어/리스닝</h3>
      <p><strong>483시간</strong> 학습</p>
      <img src="/assets/images/malhaeboca.png" alt="말해보카 학습 기록" />
    </div>

    <div class="stat-block">
      <h3>듀오링고</h3>
      <p>영어/일본어/스페인어/중국어 <strong>400시간 이상</strong> 학습</p>
      <img src="/assets/images/duolingo.png" alt="듀오링고 프로필" />
    </div>
  </section>
</BaseLayout>
