---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/english.json';
---

<BaseLayout title={data.pageTitle}>
  <section class="section">
    <h2 class="section-title">{data.sectionTitle}</h2>

    <h3 style="margin-bottom: 1rem;">자격증</h3>

    {data.certifications.map(cert => (
      <div class="cert-item">
        <div>
          <h4>{cert.title}</h4>
          <span class="score">{cert.score}</span>
        </div>
        {cert.type === 'pdf' ? (
          <div class="pdf-thumb-wrap">
            <iframe src={`${cert.filePath}#toolbar=0&navpanes=0&scrollbar=0&view=FitH`} class="pdf-thumb-frame"></iframe>
            <a href={cert.filePath} class="pdf-thumb-overlay" download>
              <span class="pdf-download-hint">📥 {cert.downloadLabel}</span>
            </a>
          </div>
        ) : (
          <img
            src={cert.filePath}
            alt={cert.imageAlt}
            style="max-width: 400px;"
          />
        )}
      </div>
    ))}
  </section>

  <section class="section">
    <h3 style="margin-bottom: 1rem;">학습 이력</h3>

    {data.learningRecords.map(record => (
      <div class="stat-block">
        <h3>{record.title}</h3>
        <p>{record.description ? `${record.description} ` : ''}<strong>{record.hours}</strong> 학습</p>
        <img src={record.image} alt={record.imageAlt} />
      </div>
    ))}
  </section>
</BaseLayout>
