---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Programming — 길철휘">
  <section class="section">
    <h2 class="section-title">코딩 테스트</h2>

    <div class="stat-block">
      <h3>
        백준 Online Judge
        <span class="badge">Platinum 5</span>
      </h3>
      <p>총 <strong>363문제</strong> 풀이</p>
      <img src="/assets/images/baekjoon.png" alt="백준 온라인 저지 활동 기록" />
    </div>

    <div class="stat-block">
      <h3>LeetCode</h3>
      <p>
        총 <strong>342문제</strong> 풀이 —
        <span class="badge">Easy 145</span>
        <span class="badge">Medium 174</span>
        <span class="badge">Hard 23</span>
      </p>
      <p>Acceptance Rate: 69.4% · Beats 97.8%</p>
      <img src="/assets/images/leetcode.png" alt="LeetCode 문제 풀이 통계" />
    </div>
  </section>
</BaseLayout>
