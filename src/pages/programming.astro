---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/programming.json';
---

<BaseLayout title={data.pageTitle}>
  <section class="section">
    <h2 class="section-title">{data.sectionTitle}</h2>

    {data.statBlocks.map(block => (
      <div class="stat-block">
        <h3>
          {block.title}
          {block.titleBadge && <span class="badge">{block.titleBadge}</span>}
        </h3>
        <p>
          {block.statPrefix} <strong>{block.statHighlight}</strong> {block.statSuffix}
          {block.badges.length > 0 && ' — '}
          {block.badges.map(b => <span class="badge">{b}</span>)}
        </p>
        {block.details && <p>{block.details}</p>}
        <img src={block.image} alt={block.imageAlt} />
      </div>
    ))}
  </section>
</BaseLayout>
