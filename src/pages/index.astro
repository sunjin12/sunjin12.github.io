---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/home.json';
---

<BaseLayout title={data.pageTitle}>
  <div class="hero">
    <img
      src={data.hero.image}
      alt={data.hero.imageAlt}
      class="hero-image"
    />
    <h1>{data.hero.title}</h1>
    {data.hero.descriptions.map(desc => <p>{desc}</p>)}
    <p class="email">
      메일: <a href={`mailto:${data.hero.email}`}>{data.hero.email}</a>
    </p>
  </div>

  <section class="section">
    <h2 class="section-title">Career Path</h2>
    <ul class="timeline">
      {data.career.map(item => <li>{item.text}</li>)}
    </ul>
  </section>

  <section class="section">
    <h2 class="section-title">What I Did</h2>
    <div class="card-grid">
      {data.cards.map(card => (
        <a href={card.link} class="card" style="text-decoration:none;color:inherit">
          <h3>{card.icon} {card.title}</h3>
          <p>{card.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Paper</h2>
    {data.papers.map(paper => (
      <div class="paper-item">
        <a
          href={paper.url}
          target="_blank"
          rel="noopener noreferrer"
        >
          {paper.title}
        </a>
      </div>
    ))}
  </section>
</BaseLayout>
